{
  "name": "organize-personal-photo",
  "version": "1.0.0",
  "description": "每月手機照片整理助手（Electron）",
  "author": "local",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n vite,electron -c auto \"vite\" \"wait-on tcp:5173 && env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:electron": "env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build && electron-builder",
    "preview": "vite build && electron ."
  },
  "build": {
    "appId": "com.local.photo-organizer",
    "productName": "照片整理助手",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "package.json"],
    "mac": { "category": "public.app-category.photography", "target": ["dmg", "zip"] }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
